# Base URL of the API as seen by the browser.
# Dev: leave empty — requests go to the relative "/api" and Vite proxies them.
# Prod: set to your API origin, e.g. https://api.fabric-pro.uz
VITE_API_BASE_URL=

# Target the Vite dev proxy forwards "/api" to (dev only).
VITE_API_PROXY_TARGET=http://46.225.154.145

# Default UI language: ru | uz | en
VITE_DEFAULT_LOCALE=ru

# App display name
VITE_APP_NAME=Fabric PRO

# Yandex Maps JS API key (warehouse location picker)
VITE_YANDEX_MAPS_API_KEY=8ac39931-6799-4d6c-9952-20df42124db5
